            "body": {
              "mode": "raw",
              "raw": "{\n  \"beneficiary_id\": 1,\n  \"case_type\": \"manual_support\",\n  \"priority\": \"medium\",\n  \"assessment_summary\": \"Manual Postman test case.\",\n  \"next_follow_up_date\": \"2026-07-15\"\n}"
            },
