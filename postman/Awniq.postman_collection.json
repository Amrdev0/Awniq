                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/case-files/1/approve"
          }
        },
        {
          "name": "Create Case Note",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Manual Postman note.\",\n  \"visibility\": \"internal\"\n}"
            },
            "url": "{{baseUrl}}/case-files/1/notes"
          }
        },
        {
          "name": "Case Documents",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/case-files/1/documents"
          }
        }
      ]
    },
    {
      "name": "Finance",
      "item": [
